  title = {Soluble Organic Molecules in Samples of the Carbonaceous Asteroid (162173) {{Ryugu}}},
  author = {Naraoka, Hiroshi and Takano, Yoshinori and Dworkin, Jason P. and Oba, Yasuhiro and Hamase, Kenji and Furusho, Aogu and Ogawa, Nanako O. and Hashiguchi, Minako and Fukushima, Kazuhiko and Aoki, Dan and Schmitt-Kopplin, Philippe and Aponte, José C. and Parker, Eric T. and Glavin, Daniel P. and McLain, Hannah L. and Elsila, Jamie E. and Graham, Heather V. and Eiler, John M. and Orthous-Daunay, Francois-Regis and Wolters, Cédric and Isa, Junko and Vuitton, Véronique and Thissen, Roland and Sakai, Saburo and Yoshimura, Toshihiro and Koga, Toshiki and Ohkouchi, Naohiko and Chikaraishi, Yoshito and Sugahara, Haruna and Mita, Hajime and Furukawa, Yoshihiro and Hertkorn, Norbert and Ruf, Alexander and Yurimoto, Hisayoshi and Nakamura, Tomoki and Noguchi, Takaaki and Okazaki, Ryuji and Yabuta, Hikaru and Sakamoto, Kanako and Tachibana, Shogo and Connolly, Harold C. and Lauretta, Dante S. and Abe, Masanao and Yada, Toru and Nishimura, Masahiro and Yogata, Kasumi and Nakato, Aiko and Yoshitake, Miwa and Suzuki, Ayako and Miyazaki, Akiko and Furuya, Shizuho and Hatakeda, Kentaro and Soejima, Hiromichi and Hitomi, Yuya and Kumagai, Kazuya and Usui, Tomohiro and Hayashi, Tasuku and Yamamoto, Daiki and Fukai, Ryota and Kitazato, Kohei and Sugita, Seiji and Namiki, Noriyuki and Arakawa, Masahiko and Ikeda, Hitoshi and Ishiguro, Masateru and Hirata, Naru and Wada, Koji and Ishihara, Yoshiaki and Noguchi, Rina and Morota, Tomokatsu and Sakatani, Naoya and Matsumoto, Koji and Senshu, Hiroki and Honda, Rie and Tatsumi, Eri and Yokota, Yasuhiro and Honda, Chikatoshi and Michikami, Tatsuhiro and Matsuoka, Moe and Miura, Akira and Noda, Hirotomo and Yamada, Tetsuya and Yoshihara, Keisuke and Kawahara, Kosuke and Ozaki, Masanobu and Iijima, Yu-ichi and Yano, Hajime and Hayakawa, Masahiko and Iwata, Takahiro and Tsukizaki, Ryudo and Sawada, Hirotaka and Hosoda, Satoshi and Ogawa, Kazunori and Okamoto, Chisato and Hirata, Naoyuki and Shirai, Kei and Shimaki, Yuri and Yamada, Manabu and Okada, Tatsuaki and Yamamoto, Yukio and Takeuchi, Hiroshi and Fujii, Atsushi and Takei, Yuto and Yoshikawa, Kento and Mimasu, Yuya and Ono, Go and Ogawa, Naoko and Kikuchi, Shota and Nakazawa, Satoru and Terui, Fuyuto and Tanaka, Satoshi and Saiki, Takanao and Yoshikawa, Makoto and Watanabe, Sei-ichiro and Tsuda, Yuichi},
  date = {2023-02-24},
